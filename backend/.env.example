# Copy this file to .env and fill in your values.
# The agent reads this file automatically on startup.

# --- Required ---
OPENAI_API_KEY=

# --- Optional (defaults shown) ---

# LLM endpoint — change to use a compatible API (e.g. Azure, local Ollama proxy)
OPENAI_BASE_URL=

# Model to use
MODEL_NAME=

# AIC that identifies this Leader agent in AIP protocol messages
LEADER_AIC=

# --- Service ---
SERVICE_HOST=0.0.0.0
SERVICE_PORT=7002

# --- mTLS (optional) ---
MTLS_BASE_DIR=
MTLS_CERT_DIR=certs
MTLS_KEY_DIR=private
MTLS_TRUST_BUNDLE=trust-bundle.pem
